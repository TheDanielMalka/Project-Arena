# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  ARENA — Environment template (English only)                             ║
# ║  Copy to `.env` and fill values. `docker compose` reads `.env` automatically. ║
# ║  Never commit real secrets.                                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ─── Database ───────────────────────────────────────────────────────────────
DB_PASSWORD=arena_secret_change_me
# Docker: arena-db and arena-engine both use DB_PASSWORD. Engine builds DATABASE_URL with URL encoding, so strong passwords work.
# Leave DATABASE_URL empty in production Docker — engine uses POSTGRES_* from compose.
# Local tools / pytest: point at localhost (encode special characters in the password with urllib.parse.quote_plus per component).
DATABASE_URL=postgresql://arena_admin:arena_secret_change_me@localhost:5432/arena

# ─── Core API ───────────────────────────────────────────────────────────────
API_SECRET=change_me_in_production
ENVIRONMENT=development
# Comma-separated list of allowed CORS origins (no spaces).
# Leave empty to use the built-in defaults: https://project-arena.com,http://localhost:3000,http://localhost
# NEVER set to "*" — the API uses cookies/Authorization, and "*" + credentials is a CSRF vector.
CORS_ALLOWED_ORIGINS=

# ─── Steam OpenID (game-account verification) ────────────────────────────────
# STEAM_API_KEY: get from https://steamcommunity.com/dev/apikey (optional but recommended — validates Steam ID at registration)
STEAM_API_KEY=
# ENGINE_BASE_URL: public URL of this engine — Steam redirects back to it after login (e.g. https://api.arena.gg)
ENGINE_BASE_URL=http://localhost:8000
# FRONTEND_URL: public URL of the React app — engine redirects here after Steam auth (e.g. https://arena.gg)
FRONTEND_URL=http://localhost:5173

# ─── Google Sign-In (Web client ID — same string in engine + Vite) ─────────
GOOGLE_OAUTH_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# ─── Slack (optional — alerts + POST /admin/alerts/test-slack) ──────────────
SLACK_ALERTS_WEBHOOK_URL=

# ─── Discord (optional) ──────────────────────────────────────────────────────
# Incoming Webhook — posts match-live summaries to #match-lobby channel.
# Create: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_LOBBY_WEBHOOK_URL=

# Bot Token — creates/deletes private per-team text channels at match start.
# Setup (5 min):
#   1. Go to https://discord.com/developers/applications → New Application
#   2. Bot tab → Add Bot → Reset Token → copy here
#   3. OAuth2 → URL Generator → scopes: bot → permissions:
#      Manage Channels, Create Instant Invite, Manage Roles, Read Messages/View Channels
#   4. Open the generated URL in browser → invite bot to your Arena server
DISCORD_BOT_TOKEN=
# Right-click your Discord server icon (Developer Mode must be ON) → Copy Server ID
DISCORD_GUILD_ID=
# (optional) Right-click the category where match channels should be created → Copy ID
# Leave blank to create channels at root level
DISCORD_MATCH_CATEGORY_ID=

# ─── Engine paths (defaults work inside Docker image) ───────────────────────
SCREENSHOT_INTERVAL=5
SCREENSHOT_DIR=/app/screenshots
EVIDENCE_DIR=/app/evidence
UPLOAD_REPORTS_DIR=

# ─── Platform wallets / exchange ────────────────────────────────────────────
PRIVATE_KEY=
WALLET_ADDRESS=
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Blockchain — ArenaEscrow (oracle key = PRIVATE_KEY for on-chain calls) ─
BLOCKCHAIN_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
CONTRACT_ADDRESS=
CHAIN_ID=97
# Deployer/owner key — on-chain pause/unpause only (kill switch). Optional.
OWNER_PRIVATE_KEY=

# ─── USDT / AT economy (engine defaults shown — omit to use code defaults) ─
USDT_CONTRACT_ADDRESS=
AT_PER_USDT=10
AT_PER_USDT_WITHDRAW=105
AT_DAILY_WITHDRAW_LIMIT=10000

# ─── BNB sender for platform payouts (optional feature branch in engine) ───
PLATFORM_WALLET_ADDRESS=

# ─── Infra / misc (optional) ────────────────────────────────────────────────
SSH_KEY_PATH=
ORACLE_API_KEY=

# ─── Desktop client protocol (GET /client/status) ───────────────────────────
CLIENT_VERSION=0.1.0
PROCESS_POLL_INTERVAL=3
HEARTBEAT_INTERVAL=15
MIN_CLIENT_VERSION=1.0.0

# ─── Internal / automation (optional) ───────────────────────────────────────
ARENA_SYSTEM_USER_ID=

# ─── Rage-quit detector (seconds) ───────────────────────────────────────────
RAGE_QUIT_THRESHOLD_SECONDS=300
RAGE_QUIT_CHECK_INTERVAL_SECONDS=60

# ─── Frontend (Vite — baked at `docker compose build`) ──────────────────────
# Public URL the browser uses to reach the engine API (e.g. https://your.domain/api)
VITE_ENGINE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001/ws
# Wallet + contract in browser — must match CONTRACT_ADDRESS + CHAIN_ID above
VITE_CONTRACT_ADDRESS=
VITE_CHAIN_ID=97
# WalletConnect Cloud project ID — required for mobile wallet QR / deep-link.
# Get yours free at https://cloud.walletconnect.com (takes 30 seconds).
# Without this, injected MetaMask extension still works on desktop; mobile wallets won't.
VITE_WALLETCONNECT_PROJECT_ID=
# Optional dev-only static Bearer for engine-api.ts (leave empty in production)
VITE_ENGINE_API_TOKEN=
# Landing / branding (optional)
VITE_LANDING_HERO_VIDEO=
VITE_AVATAR_CDN_BASE=
VITE_IDENTITY_PORTRAITS=
# Legal copy overrides (optional — placeholders in UI if unset)
VITE_LEGAL_GOVERNING_LAW=
VITE_LEGAL_ARBITRATION_BODY=
VITE_LEGAL_ARBITRATION_SEAT=
VITE_LEGAL_ENTITY_NAME=
VITE_LEGAL_REGISTERED_ADDRESS=
VITE_LEGAL_DPO_DETAILS=
VITE_LEGAL_DPO_CONTACT=

# ─── Contract tooling (Hardhat / deploy scripts — not read by Docker Engine) ─
ORACLE_ADDRESS=
BSCSCAN_API_KEY=
