# ╔══════════════════════════════════════════════════════════════╗
# ║  ARENA — Environment Variables                              ║
# ║  העתק קובץ זה ל-.env ומלא את הערכים                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Database (PostgreSQL) ────────────────────────────────────
# סיסמת בסיס הנתונים — שנה לסיסמה חזקה בפרודקשן!
DB_PASSWORD=arena_secret_change_me
# URL מלא לחיבור DB (נדרש ל-Engine)
DATABASE_URL=postgresql://arena_admin:arena_secret_change_me@localhost:5432/arena

# ─── API Secret ───────────────────────────────────────────────
# מפתח סודי לאימות בקשות בין השירותים — שנה בפרודקשן!
API_SECRET=change_me_in_production

# ─── Environment ──────────────────────────────────────────────
# הגדר ל-production בשרת האמיתי
ENVIRONMENT=development

# ─── Screenshot Capture ──────────────────────────────────────
# מרווח זמן בשניות בין צילומי מסך (ברירת מחדל: 5)
SCREENSHOT_INTERVAL=5
# נתיב שמירת צילומי מסך ל-Engine (אופציונלי, יש ברירת מחדל בקוד)
SCREENSHOT_DIR=/app/screenshots
# נתיב שמירת evidence ל-Engine (אופציונלי, יש ברירת מחדל בקוד)
EVIDENCE_DIR=/app/evidence

# ─── Crypto Wallet ────────────────────────────────────────────
# המפתח הפרטי של הארנק — אל תשתף אף פעם!
PRIVATE_KEY=your_wallet_private_key_here

# כתובת הארנק הציבורית
WALLET_ADDRESS=0xYourWalletAddressHere

# ─── Binance API ──────────────────────────────────────────────
# מפתח API מ-Binance — צור ב: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here

# מפתח סודי של Binance — נשמר רק בסביבה!
BINANCE_SECRET=your_binance_secret_here

# ─── Smart Contract (ArenaEscrow) ────────────────────────────
# RPC endpoint לרשת הבלוקצ'יין
# Dev  (BSC Testnet):  https://data-seed-prebsc-1-s1.binance.org:8545
# Prod (BSC Mainnet):  https://bsc-dataseed.binance.org
BLOCKCHAIN_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# כתובת החוזה המדופלוי — מתמלא אחרי deploy של ArenaEscrow.sol
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# מזהה הרשת: 97=BSC Testnet | 56=BSC Mainnet | 1=ETH Mainnet
CHAIN_ID=97

# ─── Infrastructure ──────────────────────────────────────────
# נתיב למפתח SSH לגישה לשרתים
SSH_KEY_PATH=/path/to/your/ssh/key.pem

# מפתח API עבור Oracle Cloud (אם רלוונטי)
ORACLE_API_KEY=your_oracle_api_key_here

# ─── Frontend (Vite) ─────────────────────────────────────────
# כתובת ה-API של ה-Engine
VITE_ENGINE_API_URL=http://localhost:8000

# כתובת WebSocket (לעדכונים בזמן אמת בלובי)
VITE_WS_URL=ws://localhost:8000/ws

# כתובת החוזה — זהה ל-CONTRACT_ADDRESS, חשופה ל-Frontend
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# מזהה רשת ל-Frontend — זהה ל-CHAIN_ID
VITE_CHAIN_ID=97
