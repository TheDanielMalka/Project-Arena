# ╔══════════════════════════════════════════════════════════════╗
# ║  ARENA — Environment Variables                              ║
# ║  Copy this file to .env and fill in your values             ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── Database (PostgreSQL) ────────────────────────────────────
# Database password — use a strong secret in production
DB_PASSWORD=arena_secret_change_me
# Full connection URL used by the Engine service
DATABASE_URL=postgresql://arena_admin:arena_secret_change_me@localhost:5432/arena

# ─── API Secret ───────────────────────────────────────────────
# Shared secret for inter-service authentication — change in production
API_SECRET=change_me_in_production

# ─── Environment ──────────────────────────────────────────────
# Set to "production" on the live server
ENVIRONMENT=development

# ─── Screenshot Capture ───────────────────────────────────────
# Interval in seconds between screenshots (default: 5)
SCREENSHOT_INTERVAL=5
# Screenshot output directory for the Engine (has a default in code)
SCREENSHOT_DIR=/app/screenshots
# Game evidence directory for the Engine (has a default in code)
EVIDENCE_DIR=/app/evidence

# ─── Crypto Wallet ────────────────────────────────────────────
# Private key of the platform wallet — NEVER share or commit this
PRIVATE_KEY=your_wallet_private_key_here

# Public wallet address
WALLET_ADDRESS=0xYourWalletAddressHere

# ─── Binance API ──────────────────────────────────────────────
# API key from Binance — create at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here

# Binance secret key — keep in environment only, never commit
BINANCE_SECRET=your_binance_secret_here

# ─── Smart Contract (ArenaEscrow) ────────────────────────────
# Blockchain RPC endpoint
# Dev  (BSC Testnet):  https://data-seed-prebsc-1-s1.binance.org:8545
# Prod (BSC Mainnet):  https://bsc-dataseed.binance.org
BLOCKCHAIN_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Deployed ArenaEscrow contract address — fill after running deploy script
CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Chain ID: 97=BSC Testnet | 56=BSC Mainnet | 1=ETH Mainnet
CHAIN_ID=97

# ─── Infrastructure ───────────────────────────────────────────
# Path to SSH key for server access
SSH_KEY_PATH=/path/to/your/ssh/key.pem

# Oracle Cloud API key (if applicable)
ORACLE_API_KEY=your_oracle_api_key_here

# ─── Frontend (Vite) ──────────────────────────────────────────
# Engine API base URL — used by the React frontend
VITE_ENGINE_API_URL=http://localhost:8000

# WebSocket URL for real-time lobby updates
VITE_WS_URL=ws://localhost:8000/ws

# Contract address exposed to frontend — must match CONTRACT_ADDRESS above
VITE_CONTRACT_ADDRESS=0xYourDeployedContractAddressHere

# Chain ID for frontend wallet interactions — must match CHAIN_ID above
VITE_CHAIN_ID=97

# Identity Studio portraits: optional S3/CDN base (trailing slash optional).
# Upload the same filenames as public/avatars/identity/*.png under this prefix.
# Example: https://cdn.yourdomain.com/static/identity/
# VITE_AVATAR_CDN_BASE=
